# ============================================================
# AISH 로컬 개발 환경변수 템플릿
# 이 파일을 .env.local로 복사하고 값을 입력하세요.
# .env.local은 .gitignore에 포함되어 있으므로 커밋되지 않습니다.
# ============================================================

# ==== Firebase Configuration (필수) ====
# Firebase Console > 프로젝트 설정에서 얻은 값
NEXT_PUBLIC_FIREBASE_API_KEY=__FIREBASE_API_KEY__
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=aish-web-v2.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aish-web-v2
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=aish-web-v2.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=__FIREBASE_MESSAGING_SENDER_ID__
NEXT_PUBLIC_FIREBASE_APP_ID=__FIREBASE_APP_ID__

# ==== Runmoa API Key (옵션: 콘텐츠 연동 기능 사용 시) ====
# Runmoa 관리자 패널에서 발급받은 API 키
# 비어있으면 강의 조회 API가 익명으로 호출됩니다.
NEXT_PUBLIC_RUNMOA_API_KEY=__RUNMOA_API_KEY__

# ==== Gemini API Key (옵션: AI 분석 기능 사용 시) ====
# Google AI Studio에서 생성한 API 키
# https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=__GEMINI_API_KEY__

# ==== Claude Cloud Function URL (선택사항) ====
# Cloud Functions 배포 후 설정
# 현재 로컬 개발에서는 필요 없음
# NEXT_PUBLIC_CLAUDE_FUNCTION_URL=

# ==== 개발용 플래그 (필요시) ====
# NODE_ENV=development
# DEBUG=aish:*
