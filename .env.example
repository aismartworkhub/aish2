# Firebase Configuration (required)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Claude Cloud Function URL (set after deploying Cloud Functions)
NEXT_PUBLIC_CLAUDE_FUNCTION_URL=

# Anthropic API Key (used by Cloud Functions, set via Firebase secrets)
# firebase functions:secrets:set ANTHROPIC_API_KEY

# Runmoa API Key (콘텐츠 연동)
NEXT_PUBLIC_RUNMOA_API_KEY=

# Gemini API Key (AI 자동분석 + 콘텐츠 큐레이션)
NEXT_PUBLIC_GEMINI_API_KEY=

# YouTube Data API v3 Key (AI 콘텐츠 자동 수집용, 관리자 설정에서도 입력 가능)
# NEXT_PUBLIC_YOUTUBE_API_KEY=
