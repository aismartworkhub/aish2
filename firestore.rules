rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: 인증된 사용자인지 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: 슈퍼관리자인지 확인
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'aismartworkhub@gmail.com';
    }

    // Helper: 관리자(superadmin 또는 admin)인지 확인
    function isAdmin() {
      return isSuperAdmin() ||
        (isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ── users 컬렉션: 역할 기반 접근 제어의 핵심 ──
    match /users/{userId} {
      // 본인 프로필 읽기 허용, 관리자는 전체 읽기 가능
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // 본인 프로필 생성/업데이트 허용 (단, role 필드 변경은 슈퍼관리자만)
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && request.resource.data.role in ['user', 'superadmin'];
      allow update: if isAuthenticated() && (
        // 본인이 role 외 필드 수정
        (request.auth.uid == userId && !('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        // 슈퍼관리자는 모든 사용자의 모든 필드 수정 가능
        || isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // 공개 읽기, 관리자만 쓰기 가능한 컬렉션들
    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /instructors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /history/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificateCohorts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificateGraduates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 사이트 설정 (공개 읽기 필요: 히어로, 배너 등)
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 비공개 컬렉션 (관리자만 읽기/쓰기)
    match /inquiries/{docId} {
      allow read, write: if isAdmin();
    }

    match /partnerApplications/{docId} {
      allow read, write: if isAdmin();
    }

    match /certificateRequests/{docId} {
      allow read, write: if isAdmin();
    }

    // admins 컬렉션 (레거시, 슈퍼관리자만 접근)
    match /admins/{docId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // 기본 거부: 위에 명시되지 않은 모든 경로
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
