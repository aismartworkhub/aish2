rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: 인증된 사용자인지 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: 슈퍼관리자인지 확인
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'aismartworkhub@gmail.com';
    }

    // Helper: 관리자(superadmin 또는 admin)인지 확인
    function isAdmin() {
      return isSuperAdmin() ||
        (isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ── users 컬렉션: 역할 기반 접근 제어의 핵심 ──
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId &&
         (!('role' in request.resource.data) || request.resource.data.role == resource.data.role))
        || isSuperAdmin()
      );
      allow delete: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // 공개 읽기, 관리자만 쓰기 가능한 컬렉션들
    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isAuthenticated() && request.resource.data.boardType == "FREE" && request.resource.data.isApproved == false);
      allow update, delete: if isAdmin();
    }

    match /faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{docId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isAuthenticated() && request.resource.data.isApproved == false);
      allow update, delete: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /instructors/{docId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.applicantUid == request.auth.uid
            && request.resource.data.status == "pending"
            && request.resource.data.isActive == false);
      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.applicantUid == request.auth.uid
            && resource.data.status == "rejected"
            && request.resource.data.status == "pending"
            && request.resource.data.isActive == false);
      allow delete: if isAdmin();
    }

    match /history/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificateCohorts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificateGraduates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminEvents/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /resources/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && resource.data.uploaderId == request.auth.uid);
    }

    // 좋아요
    match /likes/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 북마크
    match /bookmarks/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 알림
    match /notifications/{docId} {
      allow read: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
    }

    // 게시글 댓글
    match /postComments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // 강사 댓글
    match /instructorComments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // 사이트 설정
    match /siteSettings/{docId} {
      allow read: if docId != 'integrations' || isAdmin();
      allow write: if isAdmin();
    }

    // ── 통합 게시판 엔진 ──

    // 게시판 설정: 공개 읽기, 관리자만 쓰기
    match /boards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 통합 콘텐츠: 공개 읽기, 로그인 사용자 작성, 관리자/작성자 수정·삭제
    match /contents/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // 통합 댓글: 공개 읽기, 로그인 사용자 작성, 관리자/작성자 삭제
    match /contentComments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // 통합 리액션: 공개 읽기, 본인만 생성/삭제
    match /reactions/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 강의 제안: 본인만 생성, 관리자만 수정·삭제
    match /courseProposals/{docId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.applicantUid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.applicantUid == request.auth.uid
        && request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    // 비공개 컬렉션 (관리자만 읽기/쓰기)
    match /inquiries/{docId} {
      allow read, write: if isAdmin();
    }

    match /partnerApplications/{docId} {
      allow read, write: if isAdmin();
    }

    match /certificateRequests/{docId} {
      allow read, write: if isAdmin();
    }

    // admins 컬렉션 (레거시, 슈퍼관리자만 접근)
    match /admins/{docId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // 기본 거부: 위에 명시되지 않은 모든 경로
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
